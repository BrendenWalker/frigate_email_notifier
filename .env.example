# MQTT broker (Frigate or Mosquitto)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC_PREFIX=frigate

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user@example.com
SMTP_PASS=your-password
SMTP_FROM=alerts@example.com
SMTP_TO=you@example.com
SMTP_USE_TLS=true

# Alert window in the timezone configured below
ALERT_START_HOUR=19
ALERT_END_HOUR=7
EXCLUDED_LABELS=bird

# IANA timezone (for example, America/Los_Angeles or America/New_York)
TZ=UTC
