# MQTT broker (Frigate or Mosquitto)
# Original C# app used RabbitMQ at rabbitmq:5672 (guest/guest); this service uses MQTT.
MQTT_HOST=rabbitmq
MQTT_PORT=1883
MQTT_USER=guest
MQTT_PASS=guest
MQTT_TOPIC_PREFIX=frigate

# SMTP
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=your-user@example.com
SMTP_PASS=your-password
SMTP_FROM=alerts@example.com
SMTP_TO=you@example.com
SMTP_USE_TLS=true

# Alert window (local time; original used 19:00–07:00)
ALERT_START_HOUR=19
ALERT_END_HOUR=7
EXCLUDED_LABELS=bird

# Original used system local time via ToLocalTime()
TZ=America/New_York
